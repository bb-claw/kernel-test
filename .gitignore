# Build artifacts — kernel out-of-tree builds and initramfs staging/output
build/

# Compiler cache
cache/

# Test reports — generated on each run; share manually via summary.txt
reports/

# Config bisect runs — build artifacts per step; kept locally for analysis
bisect/

# Host dmesg captures and analysis files (make dmesg)
dmesg/

# Claude Code local settings (contains user-specific paths and permissions)
.claude/

# Machine-local Makefile overrides (user-specific; presets/ handles repo defaults)
local.mk

# Module build artifacts (out-of-tree builds from modules/*/Makefile)
modules/*/*.o
modules/*/*.ko
modules/*/*.mod
modules/*/*.mod.c
modules/*/*.mod.o
modules/*/Module.symvers
modules/*/modules.order
modules/*/.*.cmd
modules/*/.module-common.o

# Scratch / ad-hoc output files
*.out
todos
lsmod.arch
resume.sh

# Editor temporaries
*.swp
*.swo
*~
.DS_Store
.vscode/
.idea/
