# Config fragment applied on top of 'make tinyconfig' to produce a bootable kernel.
#
# Applied by build.sh after the tinyconfig target runs:
#   cat configs/tinyconfig.config >> <outdir>/.config
#   make olddefconfig
#
# This approach is used instead of KCONFIG_ALLCONFIG because the kernel's
# tinyconfig target overrides that variable on the command line, silently
# discarding any environment-set value.

# ── Printk / early console ────────────────────────────────────────────────────
CONFIG_PRINTK=y

# ── TTY + 8250 serial (ttyS0, needed for console=ttyS0) ─────────────────────
CONFIG_TTY=y
CONFIG_SERIAL_8250=y
CONFIG_SERIAL_8250_CONSOLE=y

# ── Initramfs (needed to run /init from the cpio) ────────────────────────────
CONFIG_BLK_DEV_INITRD=y
CONFIG_RD_GZIP=y

# ── Binary format support (ELF for busybox, SCRIPT for #!/bin/sh /init) ──────
CONFIG_BINFMT_ELF=y
CONFIG_BINFMT_SCRIPT=y

# ── tmpfs (needed for /tmp inside initramfs) ──────────────────────────────────
CONFIG_TMPFS=y
