# Config fragment for Lenovo laptop — AMD Ryzen 7 5800H + MediaTek MT7921 WiFi
#
# Base: defconfig
# defconfig already enables: r8169, cfg80211, mac80211, ahci, xhci, ext4, vfat,
#   acpi_battery, amd_iommu, amd_pstate, input_evdev, drm, sound.
#
# This fragment adds only what defconfig leaves out for this hardware.
# Build: make all NO_FETCH=1 CONFIGS=laptopconfig ARCHS=x86_64

# ── Storage ───────────────────────────────────────────────────────────────────
# NVMe SSDs (SK Hynix Gold P31 + Samsung 980 PRO) — absent from defconfig
CONFIG_BLK_DEV_NVME=y
CONFIG_NVME_CORE=y

# ── WiFi — MediaTek MT7921 802.11ax PCIe (mt7921e) ───────────────────────────
# Kconfig resolves the dependency chain (mt76 → mt76_connac_lib → mt7921_common)
CONFIG_MT7921E=y

# ── Bluetooth — MediaTek (btmtk via btusb) ───────────────────────────────────
CONFIG_BT=y
CONFIG_BTUSB=y
CONFIG_BT_MTK=y

# ── AMD power management ──────────────────────────────────────────────────────
# AMD PMC: S2Idle / suspend-to-idle for Ryzen 5000 laptops
CONFIG_AMD_PMC=y
# AMD CPU die temperature via /sys/class/hwmon
CONFIG_SENSORS_K10TEMP=y

# ── Lenovo platform ───────────────────────────────────────────────────────────
# ideapad-laptop: fn-keys, battery conservation mode, camera toggle
CONFIG_IDEAPAD_LAPTOP=y

# ── Crypto ────────────────────────────────────────────────────────────────────
# AES-NI hardware acceleration (used by dm-crypt, TLS, WireGuard)
CONFIG_CRYPTO_AES_NI_INTEL=y

# ── Filesystems ──────────────────────────────────────────────────────────────
CONFIG_BTRFS_FS=y   # common on Fedora / openSUSE
CONFIG_EXFAT_FS=y   # exFAT USB drives and Windows partitions
