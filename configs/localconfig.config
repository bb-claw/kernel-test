# Config fragment for localconfig profile (daily-driver laptop build)
#
# Base: /proc/config.gz (the running Manjaro kernel's config)
# olddefconfig adapts it to the new kernel version before this fragment runs.
#
# This fragment pins the options that Manjaro's config may leave modular or
# absent for this specific hardware, and sets a local version suffix.
#
# Hardware: Lenovo IdeaPad — AMD Ryzen 7 5800H + MediaTek MT7921 WiFi
# Build: make build NO_FETCH=1 CONFIGS=localconfig ARCHS=x86_64
#        make install CONFIGS=localconfig ARCHS=x86_64

# ── Printk / early console ────────────────────────────────────────────────────
CONFIG_PRINTK=y

# ── TTY + serial console (olddefconfig drops options unavailable on this arch) ─
# x86: 8250 UART (console=ttyS0)
CONFIG_TTY=y
CONFIG_SERIAL_8250=y
CONFIG_SERIAL_8250_CONSOLE=y
# arm64/virt: PL011 UART (console=ttyAMA0)
CONFIG_SERIAL_AMBA_PL011=y
CONFIG_SERIAL_AMBA_PL011_CONSOLE=y

# ── Initramfs (needed to run /init from the cpio) ────────────────────────────
CONFIG_BLK_DEV_INITRD=y
CONFIG_RD_GZIP=y

# ── Binary format support (ELF for busybox, SCRIPT for #!/bin/sh /init) ──────
CONFIG_BINFMT_ELF=y
CONFIG_BINFMT_SCRIPT=y

# ── tmpfs (needed for /tmp inside initramfs) ──────────────────────────────────
CONFIG_TMPFS=y

# ── Storage ───────────────────────────────────────────────────────────────────
# NVMe SSDs — build-in so the root device is reachable without initramfs hooks
CONFIG_BLK_DEV_NVME=y
CONFIG_NVME_CORE=y

# ── WiFi — MediaTek MT7921 802.11ax PCIe ─────────────────────────────────────
CONFIG_MT7921E=y

# ── Bluetooth — MediaTek (btmtk via btusb) ───────────────────────────────────
CONFIG_BT=y
CONFIG_BTUSB=y
CONFIG_BT_MTK=y

# ── AMD power management ──────────────────────────────────────────────────────
CONFIG_AMD_PMC=y
CONFIG_SENSORS_K10TEMP=y

# ── Lenovo platform ───────────────────────────────────────────────────────────
CONFIG_IDEAPAD_LAPTOP=y

# ── Crypto ────────────────────────────────────────────────────────────────────
CONFIG_CRYPTO_AES_NI_INTEL=y

# ── Filesystems ──────────────────────────────────────────────────────────────
CONFIG_BTRFS_FS=y
CONFIG_EXFAT_FS=y

# ── Debug / safety ───────────────────────────────────────────────────────────
# Magic SysRq (REISUB safe reboot, sysrq-t for traces, etc.)
# Note: systemd's /usr/lib/sysctl.d/50-default.conf overrides this to 16 at boot.
# install.sh writes /etc/sysctl.d/99-sysrq.conf to restore it to 1.
CONFIG_MAGIC_SYSRQ=y
CONFIG_MAGIC_SYSRQ_DEFAULT_ENABLE=1

# ── Debug info / BTF ─────────────────────────────────────────────────────────
# Disable DWARF debug info entirely for faster builds and smaller intermediates.
# For a daily-driver kernel, debug symbols are not needed. This also covers the
# BTF issue: pahole v1.31+ generates --btf_features=layout encoding that stable
# 7.1.x cannot validate at module load time ("failed to validate module [...] BTF: -22").
# With no debug info there is nothing for pahole to process.
CONFIG_DEBUG_INFO_NONE=y
CONFIG_DEBUG_INFO_BTF=n
CONFIG_DEBUG_INFO_BTF_MODULES=n

# ── Identify this build in uname -r ──────────────────────────────────────────
CONFIG_LOCALVERSION="-localconfig"
