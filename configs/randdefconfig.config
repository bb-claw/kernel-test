# Config fragment applied on top of 'defconfig + 300 randomly disabled options'.
#
# build.sh handles randdefconfig specially:
#   1. make defconfig          — broad, coherent baseline
#   2. shuf -n 300 =y/=m lines, set to =n  — random surface reduction
#   3. append this fragment    — force heavy subsystems off (time budget)
#                                re-pin bootability options (safety)
#   4. make olddefconfig       — cascade all dependency changes
#
# Heavy subsystems off: each can add 2-5 min when built-in; disabling them
# keeps randdefconfig reliably under 5 minutes on a 16-core machine.

# ── Printk / early console ────────────────────────────────────────────────────
CONFIG_PRINTK=y

# ── TTY + serial console (olddefconfig drops options unavailable on this arch) ─
# x86: 8250 UART (console=ttyS0)
CONFIG_TTY=y
CONFIG_SERIAL_8250=y
CONFIG_SERIAL_8250_CONSOLE=y
# arm64/virt: PL011 UART (console=ttyAMA0)
CONFIG_SERIAL_AMBA_PL011=y
CONFIG_SERIAL_AMBA_PL011_CONSOLE=y

# ── Initramfs (needed to run /init from the cpio) ────────────────────────────
CONFIG_BLK_DEV_INITRD=y
CONFIG_RD_GZIP=y

# ── Binary format support (ELF for busybox, SCRIPT for #!/bin/sh /init) ──────
CONFIG_BINFMT_ELF=y
CONFIG_BINFMT_SCRIPT=y

# ── tmpfs (needed for /tmp inside initramfs) ──────────────────────────────────
CONFIG_TMPFS=y

# ── Kernel compression algorithm  ───────────────────────────────────────────
CONFIG_KERNEL_GZIP=y

# ── Heavy subsystems (time budget) ───────────────────────────────────────────
CONFIG_DRM=n
CONFIG_SOUND=n
CONFIG_STAGING=n
CONFIG_INFINIBAND=n
CONFIG_MEDIA_SUPPORT=n
