# Config fragment applied on top of 'tinyconfig + single Kconfig option'.
#
# Used by lib/build-kconfig.sh for exhaustive per-option subsystem sweeps:
#   1. make tinyconfig                    — minimal base
#   2. cat this fragment                  — restore bootability options
#   3. make olddefconfig                  — resolve dependencies
#   4. scripts/config --enable CONFIG_OPT — enable the single option under test
#   5. make olddefconfig                  — resolve again with option enabled
#
# Identical content to rand500config.config; separate file for clarity.

# ── Printk / early console ────────────────────────────────────────────────────
CONFIG_PRINTK=y

# ── TTY + serial console (olddefconfig drops options unavailable on this arch) ─
# x86: 8250 UART (console=ttyS0)
CONFIG_TTY=y
CONFIG_SERIAL_8250=y
CONFIG_SERIAL_8250_CONSOLE=y
# arm64/virt: PL011 UART (console=ttyAMA0)
CONFIG_SERIAL_AMBA_PL011=y
CONFIG_SERIAL_AMBA_PL011_CONSOLE=y

# ── Initramfs (needed to run /init from the cpio) ────────────────────────────
CONFIG_BLK_DEV_INITRD=y
CONFIG_RD_GZIP=y

# ── Binary format support (ELF for busybox, SCRIPT for #!/bin/sh /init) ──────
CONFIG_BINFMT_ELF=y
CONFIG_BINFMT_SCRIPT=y

# ── tmpfs (needed for /tmp inside initramfs) ──────────────────────────────────
CONFIG_TMPFS=y

# ── Kernel compression algorithm  ───────────────────────────────────────────
CONFIG_KERNEL_GZIP=y
