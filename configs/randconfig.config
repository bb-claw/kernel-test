# Config fragment applied on top of 'make randconfig' to keep builds under 10 minutes.
#
# randconfig randomly sets options to y/m/n. Without constraints it can enable
# massive subsystems as =y (built into bzImage), pushing build time to 20-30+ min.
#
# Strategy:
#   CONFIG_MODULES=n  — forces all =m options to =n after olddefconfig, dramatically
#                       shrinking the compiled code surface to only =y options.
#   Disabled subsystems — the 5 heaviest optional trees by compiled line count;
#                         each can add 5-15 min when built-in on its own.

CONFIG_MODULES=n

# ── Large optional subsystems (each >5 min when built-in) ────────────────────
CONFIG_DRM=n
CONFIG_SOUND=n
CONFIG_STAGING=n
CONFIG_INFINIBAND=n
CONFIG_MEDIA_SUPPORT=n

# ── Sanitizers / coverage tools — require infrastructure absent in tinyconfig ─
# KCOV crashes early boot (per-task coverage buffer not set up).
# KASAN/KMSAN/KCSAN massively increase memory footprint and can OOM a 512M VM.
# Excluding prevents false "boot failure" noise in rand500config runs.
CONFIG_KCOV=n
CONFIG_KASAN=n
CONFIG_KMSAN=n
CONFIG_KCSAN=n
CONFIG_KFENCE=n
CONFIG_UBSAN=n

# ── Background torture tests — run continuously, flood console, starve tests ──
# RCU and lock torture tests spawn permanent kernel threads that emit hundreds
# of dmesg lines per second, starving test scripts of CPU and console bandwidth.
CONFIG_RCU_TORTURE_TEST=n
CONFIG_LOCK_TORTURE_TEST=n

# ── Kernel compression — host tool availability ───────────────────────────────
# Selecting a non-default compression format requires a matching host tool
# (lzop for LZO, lz4, zstd, bzip2, lzma) — these may not be installed,
# causing a build failure (exit 127).  gzip is universally available.
CONFIG_KERNEL_BZIP2=n
CONFIG_KERNEL_LZMA=n
CONFIG_KERNEL_XZ=n
CONFIG_KERNEL_LZO=n
CONFIG_KERNEL_LZ4=n
CONFIG_KERNEL_ZSTD=n

# ── KUnit test framework ──────────────────────────────────────────────────────
# On tinyconfig base, kunit_try_catch fails to intercept the self-test's
# intentional NULL dereference (lib/kunit/kunit-test.c:725), causing a real
# Oops instead of a caught test failure.  Use kunitconfig/kunitrandconfig
# (defconfig base) for KUnit coverage.
CONFIG_KUNIT=n
