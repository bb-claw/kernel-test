# Config fragment applied on top of 'make randconfig' to keep builds under 10 minutes.
#
# randconfig randomly sets options to y/m/n. Without constraints it can enable
# massive subsystems as =y (built into bzImage), pushing build time to 20-30+ min.
#
# Strategy:
#   CONFIG_MODULES=n  — forces all =m options to =n after olddefconfig, dramatically
#                       shrinking the compiled code surface to only =y options.
#   Disabled subsystems — the 5 heaviest optional trees by compiled line count;
#                         each can add 5-15 min when built-in on its own.

CONFIG_MODULES=n

# ── Large optional subsystems (each >5 min when built-in) ────────────────────
CONFIG_DRM=n
CONFIG_SOUND=n
CONFIG_STAGING=n
CONFIG_INFINIBAND=n
CONFIG_MEDIA_SUPPORT=n
