# KUnit randomised test profile
# Base: defconfig
# Enables the KUnit framework and guarantees the core test suites from
# kunitconfig run, then adds all KUnit test modules that randconfig makes
# available for this arch (see build.sh kunitrandconfig case).
# olddefconfig drops any test module whose dependencies are not satisfied by
# the defconfig base — only valid, buildable options survive.

# ── Printk / early console ────────────────────────────────────────────────────
CONFIG_PRINTK=y

# ── TTY + serial console (olddefconfig drops options unavailable on this arch) ─
# x86: 8250 UART (console=ttyS0)
CONFIG_TTY=y
CONFIG_SERIAL_8250=y
CONFIG_SERIAL_8250_CONSOLE=y
# arm64/virt: PL011 UART (console=ttyAMA0)
CONFIG_SERIAL_AMBA_PL011=y
CONFIG_SERIAL_AMBA_PL011_CONSOLE=y

# ── Initramfs (needed to run /init from the cpio) ────────────────────────────
CONFIG_BLK_DEV_INITRD=y
CONFIG_RD_GZIP=y

# ── Binary format support (ELF for busybox, SCRIPT for #!/bin/sh /init) ──────
CONFIG_BINFMT_ELF=y
CONFIG_BINFMT_SCRIPT=y

# ── tmpfs (needed for /tmp inside initramfs) ──────────────────────────────────
CONFIG_TMPFS=y

# ── Kernel compression algorithm  ───────────────────────────────────────────
CONFIG_KERNEL_GZIP=y

# ── KUnit framework ───────────────────────────────────────────────────────────
CONFIG_KUNIT=y

# ── KUnit self-test exclusions ────────────────────────────────────────────────
# CONFIG_KUNIT_TEST contains kunit_test_null_dereference (kunit-test.c:725):
# an intentional NULL dereference used to verify kunit_try_catch works.
# kunit_try_catch correctly catches it on defconfig base, but the Oops text
# still appears in dmesg, which vm.sh cannot distinguish from a real crash.
# CONFIG_KUNIT_ALL_TESTS selects KUNIT_TEST, so disable both.
# Applied after sampling so these override any sampled values.
CONFIG_KUNIT_TEST=n
CONFIG_KUNIT_ALL_TESTS=n

# ── Core suites — always run (same as kunitconfig baseline) ──────────────────
CONFIG_KUNIT_EXAMPLE_TEST=y
CONFIG_LIST_KUNIT_TEST=y
CONFIG_LINEAR_RANGES_KUNIT_TEST=y
CONFIG_OVERFLOW_KUNIT_TEST=y
CONFIG_RATIONAL_KUNIT_TEST=y
CONFIG_STACKINIT_KUNIT_TEST=y
CONFIG_SIPHASH_KUNIT_TEST=y
CONFIG_MEMCPY_KUNIT_TEST=y
CONFIG_SLUB_KUNIT_TEST=y
