# Config fragment applied on top of 'tinyconfig + 500 random =y options'.
#
# build.sh handles rand500config specially:
#   1. make tinyconfig        — minimal base
#   2. generate constrained randconfig in temp dir (configs/randconfig.config applied)
#   3. shuf -n 500 from the constrained randconfig — random coverage
#   4. append this fragment   — restore bootability options that random lines may clobber
#   5. make olddefconfig      — resolve all dependencies
#
# Applied last so these options always win over any conflicting random selection.

# ── Printk / early console ────────────────────────────────────────────────────
CONFIG_PRINTK=y

# ── TTY + 8250 serial (ttyS0, needed for console=ttyS0) ─────────────────────
CONFIG_TTY=y
CONFIG_SERIAL_8250=y
CONFIG_SERIAL_8250_CONSOLE=y

# ── Initramfs (needed to run /init from the cpio) ────────────────────────────
CONFIG_BLK_DEV_INITRD=y
CONFIG_RD_GZIP=y

# ── Binary format support (ELF for busybox, SCRIPT for #!/bin/sh /init) ──────
CONFIG_BINFMT_ELF=y
CONFIG_BINFMT_SCRIPT=y

# ── tmpfs (needed for /tmp inside initramfs) ──────────────────────────────────
CONFIG_TMPFS=y
