# Boot diagnostic built-in modules — enabled when CANARY=1
# boot_canary: raw UART write from early_initcall (bypasses printk)
# debug_42:    /proc/debug_42 returning "42" at module_init time
#              requires PROC_FS; enabled here so proc_create() succeeds
CONFIG_BOOT_CANARY=y
CONFIG_PROC_FS=y
CONFIG_DEBUG_42=y
