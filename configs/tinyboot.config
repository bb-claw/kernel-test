# tinyboot — minimal additions on top of tinyconfig to produce a bootable kernel.
#
# Used with KCONFIG_ALLCONFIG to force these options on while keeping everything
# else at tinyconfig's defaults (disabled).
#
# Usage:
#   KCONFIG_ALLCONFIG=configs/tinyboot.config \
#     make -C <kernel> O=<out> ARCH=x86_64 tinyconfig
#
# Or via the harness (future: make CONFIGS=tinyboot ARCHS=x86_64):
#   build.sh will apply configs/<config>.config automatically if present.

# ── Printk / early console ────────────────────────────────────────────────────
CONFIG_PRINTK=y

# ── TTY + 8250 serial (ttyS0, needed for console=ttyS0) ─────────────────────
CONFIG_TTY=y
CONFIG_SERIAL_8250=y
CONFIG_SERIAL_8250_CONSOLE=y

# ── Initramfs (needed to run /init from the cpio) ────────────────────────────
CONFIG_BLK_DEV_INITRD=y
CONFIG_RD_GZIP=y

# ── tmpfs (needed for /tmp inside initramfs) ──────────────────────────────────
CONFIG_TMPFS=y
