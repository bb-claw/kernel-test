# KUnit in-kernel test profile
# Base: defconfig
# Enables the KUnit framework and core test suites. Tests run automatically
# at boot via do_initcalls and emit KTAP output to the serial console.
# vm.sh parses KTAP lines and records KUNIT_PASS/KUNIT_FAIL in vm.status.
#
# Not a kernel make target — build.sh uses defconfig as the base.
# Build: make all NO_FETCH=1 CONFIGS=kunitconfig ARCHS=x86_64

# ── KUnit framework ───────────────────────────────────────────────────────────
CONFIG_KUNIT=y

# ── lib/ — core data structure and arithmetic tests ──────────────────────────
CONFIG_KUNIT_EXAMPLE_TEST=y         # trivial self-test; confirms the framework works
CONFIG_LIST_KUNIT_TEST=y            # linked list operations
CONFIG_LINEAR_RANGES_KUNIT_TEST=y   # linear_ranges helpers
CONFIG_OVERFLOW_KUNIT_TEST=y        # overflow arithmetic (add/sub/mul/shift)
CONFIG_RATIONAL_KUNIT_TEST=y        # rational number reduction
CONFIG_STACKINIT_KUNIT_TEST=y       # stack variable initialisation patterns
CONFIG_SIPHASH_KUNIT_TEST=y         # SipHash / HalfSipHash
CONFIG_MEMCPY_KUNIT_TEST=y          # memcpy / memmove / memset

# ── mm/ ───────────────────────────────────────────────────────────────────────
CONFIG_SLUB_KUNIT_TEST=y            # SLUB slab allocator invariants
