#!/bin/bash
# Pre-push hook: full-repo sweep on all tracked files.
# Complements pre-commit (which checks staged files only).
# Installed by: make bootstrap  (git config core.hooksPath .githooks)
set -euo pipefail

rc=0

ok()   { printf '[pre-push] ok:   %s\n' "$*"; }
fail() { printf '[pre-push] FAIL: %s\n' "$*"; rc=1; }

REPO_ROOT=$(git rev-parse --show-toplevel)

# ── 1. shellcheck ─────────────────────────────────────────────────────────────

if ! command -v shellcheck &>/dev/null; then
    printf '[pre-push] SKIP: shellcheck not installed — run: make bootstrap\n'
else
    mapfile -t SH_FILES < <(git ls-files '*.sh' | sed "s|^|$REPO_ROOT/|")
    if [[ ${#SH_FILES[@]} -eq 0 ]]; then
        ok "no .sh files tracked"
    else
        if shellcheck --severity=warning "${SH_FILES[@]}"; then
            ok "shellcheck (${#SH_FILES[@]} files)"
        else
            fail "shellcheck found issues — fix before pushing"
        fi
    fi
fi

# ── 2. Executable bit on test scripts ────────────────────────────────────────

mapfile -t TEST_FILES < <(git ls-files 'tests/*.sh' 'tests/custom/*.sh' 'tests/hardware/*.sh' | sed "s|^|$REPO_ROOT/|")
missing_x=()
for f in "${TEST_FILES[@]}"; do
    [[ -x $f ]] || missing_x+=("${f#$REPO_ROOT/}")
done

if [[ ${#missing_x[@]} -eq 0 ]]; then
    ok "executable bit (${#TEST_FILES[@]} test scripts)"
else
    for f in "${missing_x[@]}"; do
        fail "not executable: $f  (fix: chmod +x $f)"
    done
fi

# ── 3. Test script coverage in memory/test-inventory.md ──────────────────────
# Every tracked test script must have its name appear in the inventory.
# This catches tests added in a prior commit that were never documented.

INVENTORY="$REPO_ROOT/memory/test-inventory.md"
undoc=()
while IFS= read -r f; do
    name=$(basename "$f" .sh)
    grep -q "$name" "$INVENTORY" 2>/dev/null || undoc+=("$name")
done < <(git ls-files 'tests/custom/*.sh' 'tests/001_smoke.sh')
if [[ ${#undoc[@]} -eq 0 ]]; then
    n=$(git ls-files 'tests/custom/*.sh' 'tests/001_smoke.sh' | wc -l | tr -d ' ')
    ok "test-inventory coverage ($n test scripts documented)"
else
    for name in "${undoc[@]}"; do
        fail "undocumented test: $name — add entry to memory/test-inventory.md"
    done
fi

# ── 4. Design doc (feat/* and fix/* branches) ────────────────────────────────
# Every feat/ and fix/ branch must have docs/<slug>-plan.md before the first push.

BRANCH=$(git symbolic-ref --short HEAD 2>/dev/null || true)
case "$BRANCH" in
    feat/*|fix/*)
        SLUG="${BRANCH#*/}"
        PLAN="docs/${SLUG}-plan.md"
        if [[ -f "$REPO_ROOT/$PLAN" ]]; then
            ok "design doc: $PLAN"
        else
            fail "design doc missing: $PLAN  (create from docs/plan-template.md)"
        fi
        ;;
    *)
        # chore, docs, refactor — design doc is convention, not enforced
        ;;
esac

# ── 4. Memory file sizes ──────────────────────────────────────────────────────
# memory/*.md (except MEMORY.md index) must stay ≤ 150 lines.

mem_over=()
while IFS= read -r f; do
    lines=$(wc -l < "$f")
    [[ $lines -le 150 ]] || mem_over+=("${f#$REPO_ROOT/}:${lines}")
done < <(find "$REPO_ROOT/memory" -name '*.md' ! -name 'MEMORY.md' 2>/dev/null | sort)
if [[ ${#mem_over[@]} -eq 0 ]]; then
    ok "memory file sizes (all ≤ 150 lines)"
else
    for entry in "${mem_over[@]}"; do
        fail "memory file too long: ${entry%:*} (${entry##*:} lines, limit 150)"
    done
fi

# ── Result ────────────────────────────────────────────────────────────────────

if [[ $rc -eq 0 ]]; then
    printf '[pre-push] all checks passed\n'
else
    printf '[pre-push] push blocked — fix the issues above\n'
fi
exit $rc
